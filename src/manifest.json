{
  "package": "com.example.demo",
  "name": "demo",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1070,
  "icon": "/assets/images/logo.png",
  "features": [
    {
      "name": "system.prompt"
    },
    {
      "name": "system.router"
    },
    {
      "name": "system.shortcut"
    },
    {
      "name": "system.fetch"
    },
    {
      "name": "system.app"
    },
    {
      "name": "system.resident"
    },
    {
      "name": "system.configuration"
    },
    {
      "name": "system.share"
    },
    {
      "name": "system.webview"
    },
    {
      "name": "system.notification"
    }
  ],
  "permissions": [
    {
      "origin": "*"
    }
  ],
  "template/official": "demo-template",
  "config": {
    "logLevel": "debug"
  },
  "router": {
    "entry": "pages/SliderDemo",
    "pages": {
      "pages/SliderDemo": {
        "component": "index"
      }
    },
    "widgets": {
      "widgets/widget4x4": {
        "name": "widget4x4",
        "description": "快应用卡片展示",
        "component": "index",
        "path": "/widgets/widget4x4",
        "minPlatformVersion": 1032,
        "targetManufactorys": ["oppo"],
        "features": [],
        "params": {
          "size": "4x4"
        },
        "sizes":[
               "4x4:310x310"
        ]
      }
    }
  },
  "display": {
    "titleBarBackgroundColor": "#f2f2f2",
    "titleBarTextColor": "#414141"
  }
}
