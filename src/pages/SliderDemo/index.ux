  flex-direction: column;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 8px;
  height: 300px;
}

.current-index {
  font-size: 28px;
  color: #666;
  margin-top: 20px;
  text-align: center;
}

.control-section {
  margin-top: 40px;
  flex-direction: column;
}

.control-title {
  font-size: 32px;
  font-weight: bold;
  color: #333;
  margin-bottom: 20px;
  text-align: center;
}

.control-buttons {
  flex-direction: row;
  justify-content: center;
  margin-bottom: 20px;
}

.btn {
  padding: 16px 32px;
  margin: 0 10px;
  background-color: #fff;
  border: 2px solid #ddd;
  border-radius: 8px;
}

.btn-primary {
  background-color: #4A90E2;
  border-color: #4A90E2;
}

