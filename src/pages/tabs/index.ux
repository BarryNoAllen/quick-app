<import name="custom-tab-bar" src="./components/tab-bar"></import>
<import name="home-page" src="./components/home-page"></import>
<import name="category-page" src="./components/category-page"></import>
<import name="web-page" src="./components/web-page"></import>
<import name="profile-page" src="./components/profile-page"></import>

<template>
  <div class="container">
    <tabs class="tabs" onchange="onTabChange" index="{{currentIndex}}">
      <tab-content class="tab-content">
        <home-page items="{{homeItems}}"></home-page>
        <category-page 
          categories="{{categories}}" 
          onitemclick="onCategoryClick"
        ></category-page>
        <web-page url="{{webUrl}}"></web-page>
        <profile-page 
          menu-items="{{menuItems}}" 
          onmenuclick="onMenuClick"
        ></profile-page>
      </tab-content>
      <custom-tab-bar 
        current-index="{{currentIndex}}" 
        tab-list="{{tabList}}" 
        onswitch="onTabSwitch"
      ></custom-tab-bar>
    </tabs>
  </div>
</template>

<script>
export default {
  data: {
    currentIndex: 0,
    
    tabList: [
      { icon: '🏠', label: '首页' },
      { icon: '📂', label: '分类' },
