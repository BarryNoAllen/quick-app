      { title: '热门活动', desc: '参与即有机会赢取大奖' },
      { title: '新品上架', desc: '最新商品第一时间了解' },
      { title: '限时特惠', desc: '超值优惠不容错过' }
    ],
    
    categories: [
      { name: '美食', icon: '🍔', color: '#FF6B6B' },
      { name: '购物', icon: '🛍️', color: '#4ECDC4' },
      { name: '娱乐', icon: '🎮', color: '#45B7D1' },
      { name: '出行', icon: '🚗', color: '#96CEB4' },
      { name: '酒店', icon: '🏨', color: '#FFEAA7' },
      { name: '电影', icon: '🎬', color: '#DDA0DD' },
      { name: '音乐', icon: '🎵', color: '#98D8C8' },
      { name: '运动', icon: '⚽', color: '#F7DC6F' }
